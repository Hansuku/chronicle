{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://earth-chronicle.local/schemas/events.schema.json",
  "title": "地球编年史事件内容包",
  "type": "object",
  "required": ["version", "events"],
  "properties": {
    "$schema": { "type": "string" },
    "version": { "const": 1 },
    "events": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "year", "location", "detail", "coordinates", "type"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
          "name": { "type": "string", "minLength": 1 },
          "year": { "type": "integer", "minimum": -3400, "maximum": 2026 },
          "dateText": { "type": "string" },
          "calendar": { "type": "string" },
          "location": { "type": "string", "minLength": 1 },
          "detail": { "type": "string", "minLength": 1 },
          "coordinates": {
            "type": "array",
            "prefixItems": [
              { "type": "number", "minimum": -180, "maximum": 180 },
              { "type": "number", "minimum": -90, "maximum": 90 }
            ],
            "minItems": 2,
            "maxItems": 2
          },
          "type": {
            "enum": ["state", "technology", "trade", "writing", "culture"]
          },
          "relatedPolities": { "type": "array", "items": { "type": "string" } },
          "tags": { "type": "array", "items": { "type": "string" } },
          "sources": { "type": "array", "items": { "type": "string" } },
          "confidence": { "enum": ["high", "medium", "low"] },
          "editorialNote": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
